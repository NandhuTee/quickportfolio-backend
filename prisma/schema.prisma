generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int         @id @default(autoincrement())
  name       String
  email      String      @unique
  password   String
  createdAt  DateTime    @default(now())

  portfolios Portfolio[]   // one user can have many portfolios
}

model Portfolio {
  id        Int      @id @default(autoincrement())
  bio       String?
  skills    String[]

  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}